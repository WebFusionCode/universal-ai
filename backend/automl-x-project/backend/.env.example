# Backend Environment Variables

# Database Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=automl_db

# Security
SECRET_KEY=your-secret-key-here-generate-a-secure-random-key
CORS_ORIGINS=*

# AI/LLM Integration (Optional - for AI chat features)
# Get your key from Emergent platform
EMERGENT_LLM_KEY=your-emergent-llm-key-here

# Note: Never commit this file with real credentials to version control
